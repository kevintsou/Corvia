# corvia.toml — Corvia static analysis configuration for secure_boot
# SOC_ID: PS5801 (default). To use PT5801, replace all PS5801 entries below.
#
# Include paths mirror the TF-A Makefile logic:
#   find common/include/phison_hw/$(SOC_ID) -type d  (all subdirs)
#   + common/config, common/sal and its subdirs

[paths]
use_cpp = true

include = [
    # SAL and build types (sal_conf.h, sal_build_types.h, etc.)
    "common/sal",
    "common/sal/build",
    "common/sal/log",
    "common/sal/utils",

    # Project config (conf_libs.h, conf_efuse.h, etc.)
    "common/config",

    # common/include root — needed for <phison_hw/...> angle-bracket includes
    "common/include",
    "common/include/phison_hw",
    "common/include/phison_hw/uart",

    # PS5801 — all subdirs (mirrors: find common/include/phison_hw/PS5801 -type d)
    "common/include/phison_hw/PS5801",
    "common/include/phison_hw/PS5801/dal",
    "common/include/phison_hw/PS5801/dal/ahb",
    "common/include/phison_hw/PS5801/dal/apu",
    "common/include/phison_hw/PS5801/dal/i2c",
    "common/include/phison_hw/PS5801/dal/nvme",
    "common/include/phison_hw/PS5801/dal/sec",
    "common/include/phison_hw/PS5801/dal/sys",
    "common/include/phison_hw/PS5801/dal/ufs",
    "common/include/phison_hw/PS5801/dal/unipro",
    "common/include/phison_hw/PS5801/hal",
    "common/include/phison_hw/PS5801/hal/ahb",
    "common/include/phison_hw/PS5801/hal/host",
    "common/include/phison_hw/PS5801/hal/mrdb",
    "common/include/phison_hw/PS5801/hal/npu",
    "common/include/phison_hw/PS5801/hal/pip",
    "common/include/phison_hw/PS5801/hal/sec",
    "common/include/phison_hw/PS5801/hal/sec/ntt",
    "common/include/phison_hw/PS5801/hal/sys",
    "common/include/phison_hw/PS5801/hal/ufs",
    "common/include/phison_hw/PS5801/reg",
    "common/include/phison_hw/PS5801/reg/ahb",
    "common/include/phison_hw/PS5801/reg/apu",
    "common/include/phison_hw/PS5801/reg/i2c",
    "common/include/phison_hw/PS5801/reg/mrdb",
    "common/include/phison_hw/PS5801/reg/nvme",
    "common/include/phison_hw/PS5801/reg/pasc",
    "common/include/phison_hw/PS5801/reg/pcie",
    "common/include/phison_hw/PS5801/reg/sec",
    "common/include/phison_hw/PS5801/reg/spi",
    "common/include/phison_hw/PS5801/reg/sys",
    "common/include/phison_hw/PS5801/reg/uart",
    "common/include/phison_hw/PS5801/reg/ufs",
]

# Preprocessor defines — match build defaults
cpp_args = "-DSOC_ID=PS5801 -DPS5801=2 -DPT5801=1"

[severity]
# Firmware projects often contain target/toolchain-specific preprocessor
# constructs that host clang can only diagnose. Keep the scan and symbol
# export usable while still surfacing those parser diagnostics in the report.
"parser" = "warning"

[output]
format = "text"

[cache]
enabled = true
dir     = ".corvia_cache"
